// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/jekyll
{
    // The following block is taken from the jekyll template https://github.com/devcontainers/templates/tree/main/src/jekyll
    "id": "jekyll",
    "version": "2.2.2",
    "name": "Jekyll",
    "description": "Develop static sites with Jekyll, includes everything you need to get up and running.",
    "documentationURL": "https://github.com/devcontainers/templates/tree/main/src/jekyll",
    "publisher": "Dev Container Spec Maintainers",
    "licenseURL": "https://github.com/devcontainers/templates/blob/main/LICENSE",
    "options": {
        "imageVariant": {
            "type": "string",
            "description": "Debian OS version (use bookworm, or bullseye on local arm64/Apple Silicon):",
            "proposals": [
                "bookworm",
                "bullseye",
                "buster"
            ],
            "default": "bullseye"
        }
    },
   "platforms": [
        "Ruby",
        "Jekyll"
    ],
    "optionalPaths": [
        ".github/*"
    ],
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// The following section mounts pre-installed cached Gems into the container.
	// This could shave off a bit of the build time for the container, in cases where the required gems have been previously installed.
	// Since we rarely change the dependencies, this should actually apply to most cases.
	"mounts": [
		"source=${localEnv:HOME}/.bundle,target=/home/vscode/.bundle,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.gem,target=/home/vscode/.gem,type=bind,consistency=cached"
	],

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Commands to be ran afer the container is created.
	// This forces the sass-embedded version to be the one specified in Gemfile.
	// This ensures that the page will build even after deprecation of some functions that currently throw warnings.
	// Affected functions `@import`, `lighten()`, and `darken()`
	"postCreateCommand": "bundle install",


	// Run commands after the container on startup. This will keep rendering the website and serving it for preview.
	"postStartCommand": "bundle exec jekyll serve",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
